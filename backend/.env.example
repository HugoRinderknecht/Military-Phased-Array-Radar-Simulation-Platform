# Radar Simulation Platform - Environment Configuration

# Application Settings
APP_NAME=RadarSimulationPlatform
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Data Storage
DATA_DIR=./data
LOG_DIR=./logs
MAX_UPLOAD_SIZE=10485760

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# WebSocket
WS_MESSAGE_QUEUE_SIZE=100

# Simulation Settings
MAX_SIMULTANEOUS_SIMULATIONS=10
SIMULATION_TIMEOUT=3600

# File Storage
ALLOWED_EXTENSIONS=["json","h5","hdf5","csv"]
MAX_FILE_SIZE_JSON=10485760
MAX_FILE_SIZE_HDF5=1073741824
